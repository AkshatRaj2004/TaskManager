pipeline {
    agent any

    environment {
        IMAGE_NAME = "taskmanager-backend"
        CONTAINER_NAME = "taskmanager-backend-stable"
        PORT = "5000"
    }

    stages {
        stage('Pull Code') {
            steps {
                echo 'Pulling latest code from repository...'
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                echo 'Installing backend npm packages...'
                dir('TaskManager/backend') {
                    bat 'npm install'
                }
            }
        }

        stage('Run Checks') {
            steps {
                echo 'Running project structure checks...'
                dir('TaskManager/backend') {
                    bat 'node --check src/server.js'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                echo "Building Docker image: ${IMAGE_NAME}:${BUILD_NUMBER}"
                dir('TaskManager') {
                    bat "docker build -t ${IMAGE_NAME}:${BUILD_NUMBER} -f backend/Dockerfile ./backend"
                }
            }
        }

        stage('Deploy Container') {
            steps {
                echo 'Deploying container...'